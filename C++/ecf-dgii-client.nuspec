<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>ecf-dgii-client.cpp</id>
    <version>0.1.0</version>
    <title>ECF DGII C++ Client</title>
    <authors>Puntoos</authors>
    <owners>Puntoos</owners>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/puntoos/ecf_dgii_clients</projectUrl>
    <description>C++ SDK client for the ECF DGII API (Electronic Fiscal Receipt - Dominican Republic). Provides auto-generated models and HTTP client plus a high-level sendEcf() method with automatic routing, polling, and error handling.</description>
    <releaseNotes>Initial release.</releaseNotes>
    <copyright>Copyright (c) 2024 Puntoos</copyright>
    <tags>ecf dgii dominican-republic electronic-invoice fiscal api-client cpp native</tags>
    <repository type="git" url="https://github.com/puntoos/ecf_dgii_clients.git" />
    <dependencies>
      <group targetFramework="native">
      </group>
    </dependencies>
  </metadata>
  <files>
    <!-- Headers -->
    <file src="include\**\*.h" target="build\native\include" />

    <!-- CMake config -->
    <file src="CMakeLists.txt" target="build\native" />
    <file src="Config.cmake.in" target="build\native" />

    <!-- Sources (for source-based consumption) -->
    <file src="src\**\*.cpp" target="build\native\src" />

    <!-- License -->
    <file src="LICENSE" target="" />

    <!-- MSBuild integration -->
    <file src="nuget\ecf-dgii-client.cpp.targets" target="build\native\ecf-dgii-client.cpp.targets" />
  </files>
</package>
